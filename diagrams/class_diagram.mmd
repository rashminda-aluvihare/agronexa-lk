classDiagram
    direction TB

    %% Presentation Layer / Client-side Router
    class ReactFrontend {
        +BuyerDashboard
        +SellerDashboard
        +AdminPanel
        +ChatWindow
        +handleRoleSwitch()
        +renderCharts()
    }

    %% Backend Routing
    class ExpressApp {
        +createApp()
        +apiRouter
    }

    class APIRoutes {
        +/login
        +/auth
        +/seller
        +/buyer
        +/admin
        +/profile
        +/transport
        +/chat
        +/ledger
    }

    %% Middlewares
    class Middlewares {
        +authMiddleware(req, res, next)
        +roleMiddleware(allowedRoles)
        +errorHandler(err, req, res, next)
    }

    %% Controllers
    class AuthController {
        +sendOtp(req, res, next)
        +verifyOtp(req, res, next)
        +registerWithOtp(req, res, next)
        +login(req, res, next)
        +logout(req, res, next)
    }

    class AdminController {
        +getPendingUsers(req, res, next)
        +approveUser(req, res, next)
        +rejectUser(req, res, next)
        +getAllUsers(req, res, next)
        +getSystemStats(req, res, next)
    }

    class CropController {
        +createListing(req, res, next)
        +getListings(req, res, next)
        +updateListing(req, res, next)
        +deleteListing(req, res, next)
    }

    class EquipmentController {
        +createListing(req, res, next)
        +createBooking(req, res, next)
        +confirmBooking(req, res, next)
        +returnEquipment(req, res, next)
    }

    class RequestController {
        +createBroadcast(req, res, next)
        +respondToBroadcast(req, res, next)
        +getBroadcasts(req, res, next)
    }

    class LedgerController {
        +getLedger(req, res, next)
        +verifyLedger(req, res, next)
    }

    class ChatController {
        +getMessages(req, res, next)
        +getActiveChats(req, res, next)
    }

    %% Services
    class LedgerService {
        +hashRecord(record, prevHash) string
        +writeLedgerEntry(listingId, listingType, renterId, ownerId, amount, durationDays) object
        +verifyLedgerChain() object
    }

    class TwilioService {
        +sendOtp(phone) object
        +verifyOtp(phone, code) object
        +normalizePhoneToE164(phone) string
    }

    class AuditService {
        +logAction(userId, action, ip, details) void
    }

    class NotificationService {
        +sendNotification(userId, type, title, body) object
        +sendSmsIfEnabled(phone, text) void
    }

    %% Database Connector
    class Database {
        +pool: pg.Pool
        +query(text, params) pg.Result
        +initDatabase() void
    }

    %% Core dependencies
    ReactFrontend --> ExpressApp : HTTPS / Socket.IO
    ExpressApp --> APIRoutes : Routing
    APIRoutes --> Middlewares : Intercepts
    APIRoutes --> AuthController
    APIRoutes --> AdminController
    APIRoutes --> CropController
    APIRoutes --> EquipmentController
    APIRoutes --> RequestController
    APIRoutes --> LedgerController
    APIRoutes --> ChatController

    AuthController --> TwilioService
    AuthController --> AuditService
    AuthController --> Database
    AdminController --> AuditService
    AdminController --> Database
    CropController --> Database
    EquipmentController --> LedgerService
    EquipmentController --> Database
    RequestController --> NotificationService
    RequestController --> Database
    LedgerController --> LedgerService
    ChatController --> Database

    LedgerService --> Database
    NotificationService --> Database
    NotificationService --> TwilioService
    AuditService --> Database

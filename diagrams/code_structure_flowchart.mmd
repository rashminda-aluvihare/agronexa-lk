flowchart TD
    Client["Client / User Frontend (React or HTML)"]
    ServerEntry["backend/src/server.js (HTTP / WS Listener)"]
    AppConfig["backend/src/app.js (Express Middleware Pool)"]
    Router["backend/src/routes/index.js (Router Gateway)"]
    AuthCheck{"Auth Middleware (authRequired?)"}
    RoleCheck{"Role Middleware (requireRole?)"}
    Controller["backend/src/controllers/ (e.g. crop.controller.js)"]
    Service["backend/src/services/ (e.g. ledger.service.js)"]
    Database["backend/src/config/db.js (PostgreSQL Node Client Pool)"]
    Postgres[("PostgreSQL Relational DB")]

    %% Flow Arrows
    Client -- "1. Sends HTTPS Request / WebSocket Event" --> ServerEntry
    ServerEntry -- "2. Pipes to Express Handler" --> AppConfig
    AppConfig -- "3. Matches API Route Path" --> Router
    Router -- "4. Verifies Auth Headers (JWT)" --> AuthCheck
    
    AuthCheck -- "Invalid Token / Unauthorized" --> ErrRes["401 Unauthorized Response"]
    AuthCheck -- "Valid" --> RoleCheck
    
    RoleCheck -- "Role Mismatch (Forbidden)" --> ForbRes["403 Forbidden Response"]
    RoleCheck -- "Authorized Role" --> Controller
    
    Controller -- "5. Calls Utility Functions" --> Service
    Controller -- "6. Executes SQL Query" --> Database
    Service -- "7. Computes Hash / Hashing Chain" --> Database
    Database -- "8. Queries relational tables" --> Postgres
    
    Postgres -- "9. Returns Data Rows" --> Database
    Database -- "10. Returns Query Rows" --> Controller
    Controller -- "11. Resolves JSON Payload" --> Client
    
    ErrRes --> Client
    ForbRes --> Client

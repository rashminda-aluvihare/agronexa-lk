sequenceDiagram
    autonumber
    actor User as User / Client
    participant FE as React Frontend
    participant Router as Express API Router
    participant AuthCtrl as Auth Controller
    participant DB as PostgreSQL Database
    participant Audit as Audit Service
    participant JWT as JWT Module

    User->>FE: Enter Email & Password
    FE->>Router: POST /api/login {email, password}
    Router->>AuthCtrl: login(req, res)
    
    rect rgb(230, 245, 255)
        Note over AuthCtrl, DB: Check Admin Credentials
        AuthCtrl->>AuthCtrl: Compare credentials with ADMIN_EMAIL & ADMIN_PASSWORD
        alt Is Admin Credentials
            AuthCtrl->>JWT: sign({ id: 0, role: "admin", name: "Admin" })
            JWT-->>AuthCtrl: Return token
            AuthCtrl->>Audit: logAction(0, "ADMIN_LOGIN")
            AuthCtrl-->>FE: Return success {token, user: Admin}
            FE-->>User: Redirect to Admin Dashboard
        end
    end

    rect rgb(255, 245, 230)
        Note over AuthCtrl, DB: Process Normal User
        AuthCtrl->>DB: SELECT * FROM users WHERE email = ?
        DB-->>AuthCtrl: Return User Record
        
        alt User Not Found
            AuthCtrl-->>FE: 401 Invalid email or password
            FE-->>User: Show credentials error
        else User Found
            alt Account Locked
                AuthCtrl->>AuthCtrl: Check if locked_until > Current Time
                AuthCtrl-->>FE: 403 Account Locked (Remaining Mins)
                FE-->>User: Show Lockout warning
            else Account Active
                AuthCtrl->>AuthCtrl: Compare bcrypt.compare(password, user.password_hash)
                alt Password Mismatch (Failed Login)
                    AuthCtrl->>AuthCtrl: Increment failed_login_attempts
                    alt Failed Attempts >= 5
                        AuthCtrl->>DB: UPDATE users SET failed_login_attempts = 5, locked_until = Now + 30 mins
                        AuthCtrl-->>FE: 403 Locked for 30 minutes
                        FE-->>User: Show Account Locked warning
                    else Failed Attempts < 5
                        AuthCtrl->>DB: UPDATE users SET failed_login_attempts = newAttempts
                        AuthCtrl-->>FE: 401 Invalid credentials (show remaining attempts)
                        FE-->>User: Show Invalid Password (X attempts remaining)
                    end
                else Password Match (Successful Login)
                    alt Failed Attempts > 0
                        AuthCtrl->>DB: UPDATE users SET failed_login_attempts = 0, locked_until = NULL
                    end
                    alt Account Status is 'pending'
                        AuthCtrl-->>FE: 403 Pending approval
                        FE-->>User: Show "Awaiting Admin Verification"
                    else Account Status is 'rejected'
                        AuthCtrl-->>FE: 403 Account Rejected (show rejection reason)
                        FE-->>User: Show "Verification Rejected: Reason"
                    else Account Status is 'approved'
                        AuthCtrl->>JWT: sign({ id, email, role, name })
                        JWT-->>AuthCtrl: Return token
                        AuthCtrl->>Audit: logAction(user.id, "USER_LOGIN")
                        AuthCtrl-->>FE: Return success {token, user}
                        FE-->>User: Redirect to Dashboard (Buyer / Seller)
                    end
                end
            end
        end
    end
